# MindMirror — Environment Variables
# Copy this file to `.env` and fill the values.
# All EXPO_PUBLIC_* vars are inlined into the JS bundle at build time.

# ---------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ---------------------------------------------------------------------
# Gemini — pick ONE of the two configurations
# ---------------------------------------------------------------------
#
# (A) DEV / LOCAL — call Google directly with a key that lives in the bundle.
#     Convenient, but anyone who reverse-engineers your APK can use the key.
EXPO_PUBLIC_GEMINI_API_KEY=your-gemini-api-key
EXPO_PUBLIC_GEMINI_MODEL=gemini-1.5-flash
#
# (B) PRODUCTION — route through a Supabase Edge Function (`gemini-proxy`)
#     that holds the API key server-side. Recommended for any public build.
#     If this is set, the client uses it instead of the direct key above.
# EXPO_PUBLIC_GEMINI_PROXY_URL=https://your-project.supabase.co/functions/v1/gemini-proxy

# ---------------------------------------------------------------------
# Razorpay
# ---------------------------------------------------------------------
EXPO_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxx

# ---------------------------------------------------------------------
# Google Sign-In (optional — leave blank to hide the button)
# ---------------------------------------------------------------------
# 1. Google Cloud Console → OAuth 2.0 Client IDs.
# 2. Create a "Web application" client → paste its ID + secret into
#    Supabase → Auth → Providers → Google. Use the Web client ID below.
# 3. Create an "Android" client (with your debug + upload SHA-1).
# 4. (iOS) create an "iOS" client and put it in EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
